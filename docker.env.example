# Copy to .env before running docker compose if you need to override defaults.
# Defaults are local-demo only. Do not reuse this password for shared systems.
POSTGRES_DB=civiccode
POSTGRES_USER=civiccode
POSTGRES_PASSWORD=civiccode-local-only
CIVICCODE_PORT=8000
DATABASE_URL=postgresql+psycopg2://civiccode:civiccode-local-only@postgres:5432/civiccode
CIVICCODE_SOURCE_REGISTRY_DB_URL=postgresql+psycopg2://civiccode:civiccode-local-only@postgres:5432/civiccode
CIVICCODE_DEMO_SEED=1
CIVICCODE_DEMO_ACTOR=demo-seed@brookfield.example.gov
